{
  "doctype": "DocType",
  "name": "Site Configuration",
  "module": "Av Tools",
  "custom": 0,
  "istable": 0,
  "editable_grid": 0,
  "track_changes": 1,
  "engine": "InnoDB",
  "allow_rename": 1,
  "autoname": "field:title",
  "field_order": ["title", "description", "sites_section", "sites"],
  "fields": [
    {
      "fieldname": "title",
      "label": "Title",
      "fieldtype": "Data",
      "reqd": 1,
      "unique": 1,
      "in_list_view": 1,
      "in_standard_filter": 1,
      "description": "Configuration name, e.g. \"Production Sites\""
    },
    {
      "fieldname": "description",
      "label": "Description",
      "fieldtype": "Small Text",
      "in_list_view": 0,
      "description": "Short note about which environments / sites are covered in this configuration"
    },
    {
      "fieldname": "sites_section",
      "label": "Sites",
      "fieldtype": "Section Break",
      "collapsible": 0
    },
    {
      "fieldname": "sites",
      "label": "Sites",
      "fieldtype": "Table",
      "options": "Site Configuration Entry",
      "reqd": 1,
      "description": "List of Frappe/ERPNext sites where user accounts will be managed"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1,
      "email": 1,
      "export": 1,
      "print": 1,
      "report": 1,
      "share": 1
    }
  ],
  "sort_field": "modified",
  "sort_order": "DESC",
  "index_web_pages_for_search": 1,
  "grid_page_length": 50,
  "row_format": "Dynamic",
  "rows_threshold_for_grid_search": 20,
  "actions": [],
  "links": [],
  "states": []
}
